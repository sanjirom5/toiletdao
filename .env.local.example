# Supabase — copy this file to `.env.local` and fill in your project's values.
# Both are PUBLIC keys (they ship in the browser bundle); safe to expose.
# Find them in Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# The Oracle — GPT-4o-mini urgency appraisal.
# SERVER-ONLY (no NEXT_PUBLIC_ prefix) so the key never ships to the browser.
# Without it the Oracle still works via a local keyword fallback.
OPENAI_API_KEY=sk-...
